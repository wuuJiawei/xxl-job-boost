# Shared admin settings
XXL_JOB_ADMIN_PORT=8080
XXL_JOB_ADMIN_CONTEXT_PATH=/xxl-job-admin

# MySQL settings. Values are applied only when a new data volume is initialized.
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_USER=xxl_job
MYSQL_PASSWORD=change_this_app_password

# Used only by docker/docker-compose.yml, which runs MySQL separately.
MYSQL_HOST_PORT=3306
MYSQL_PATH=/data/xxl-job-boost/mysql
